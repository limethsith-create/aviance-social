# ===========================================
# Aviance Social - Environment Variables
# ===========================================

# Vercel Postgres
# Obtain from: Vercel Dashboard > Storage > Postgres
DATABASE_URL="postgres://default:password@ep-xxx.us-east-1.aws.neon.tech:5432/verceldb?sslmode=require"

# Vercel Blob Storage
# Obtain from: Vercel Dashboard > Storage > Blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"

# LinkedIn OAuth 2.0
# Obtain from: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# Meta (Facebook/Instagram) OAuth
# Obtain from: https://developers.facebook.com/apps
META_APP_ID=""
META_APP_SECRET=""

# Application URL (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron Job Secret
# Used to authenticate Vercel Cron requests to /api/publish
# Generate with: openssl rand -hex 32
CRON_SECRET=""
